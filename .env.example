# Local environment variables for `make` targets. Copy to `.env` and fill in.
# `.env` is git-ignored; never commit credentials.
#
# Loaded automatically by the Makefile's `.env` loader (see top of Makefile).
# Format rules — Makefile syntax, NOT bash:
#   - `KEY=value` (one per line)
#   - NO quotes around values
#   - NO `export` prefix
#   - NO spaces around `=`
#   - `#` always means comment

# SUSE Registry credentials for `make verify-nim-live` (P2-1 NIM Discovery).
# Obtain from your SCC account at https://scc.suse.com/.
SUSE_REG_USER=
SUSE_REG_TOKEN=

# SUSE Application Collection credentials for `make verify-appco-live`
# (P2-2 source_collection client). Per ARCHITECTURE.md §13.2 these are
# *distinct* from the registry credentials above (Settings.spec.applicationCollection
# vs Settings.spec.suseRegistry), even though customers often reuse the same
# value. Obtain from https://apps.rancher.io/ → "My Account".
SUSE_APPCO_USER=
SUSE_APPCO_TOKEN=
